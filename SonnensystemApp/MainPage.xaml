<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SonnensystemApp.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#050816">

    <Grid RowDefinitions="Auto,*">

        <!-- Top panel -->
        <Border
            Grid.Row="0"
            BackgroundColor="transparent"
            StrokeThickness="0"
            Padding="16,14,16,12">

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="24">

                <!-- Left side -->
                <VerticalStackLayout Grid.Column="0"
                                     Spacing="2"
                                     VerticalOptions="Center">
                    <Label Text="Sonnensystem App"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White" />

                    <Label Text="Echtzeit-Visualisierung der Planeten"
                           FontSize="14"
                           TextColor="#B8C0D9" />
                </VerticalStackLayout>

                <!-- Right side -->
                <HorizontalStackLayout Grid.Column="1"
                                       Spacing="8"
                                       HorizontalOptions="End"
                                       VerticalOptions="Center">

                    <Button Text="1x"
                            Clicked="Speed1x"
                            BackgroundColor="#4F46E5"
                            TextColor="White" />

                    <Button Text="10x"
                            Clicked="Speed10x"
                            BackgroundColor="#4F46E5"
                            TextColor="White" />

                    <Button Text="100x"
                            Clicked="Speed100x"
                            BackgroundColor="#4F46E5"
                            TextColor="White" />

                    <Button Text="1000x"
                            Clicked="Speed1000x"
                            BackgroundColor="#4F46E5"
                            TextColor="White" />

                    <Button Text="10M x"
                            Clicked="SpeedMega"
                            BackgroundColor="#4F46E5"
                            TextColor="White" />
                </HorizontalStackLayout>

            </Grid>
        </Border>

        <!-- Canvas -->
        <GraphicsView
            x:Name="SolarSystemCanvas"
            Grid.Row="1"
            HorizontalOptions="Fill"
            VerticalOptions="Fill" />
    </Grid>
</ContentPage>