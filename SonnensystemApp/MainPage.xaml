<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SonnensystemApp.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#050816">

    <Grid RowDefinitions="Auto,*" Padding="12">
        <VerticalStackLayout Spacing="4">
            <Label Text="Sonnensystem App"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White" />

            <Label Text="Vereinfachte Echtzeit-Visualisierung der Planeten"
                   FontSize="14"
                   TextColor="#B8C0D9" />
        </VerticalStackLayout>

        <HorizontalStackLayout Spacing="8" Margin="0,10,0,0">

            <Button Text="1x" Clicked="Speed1x"/>
            <Button Text="10x" Clicked="Speed10x"/>
            <Button Text="100x" Clicked="Speed100x"/>
            <Button Text="1000x" Clicked="Speed1000x"/>
            <Button Text="10M x" Clicked="SpeedMega"/>

        </HorizontalStackLayout>

        <GraphicsView
            x:Name="SolarSystemCanvas"
            Grid.Row="1"
            Margin="0,16,0,0"
            HorizontalOptions="Fill"
            VerticalOptions="Fill" />
    </Grid>
</ContentPage>